# RegiMenu Mobile — env reference. Copy this file to `.env` (gitignored) and
# fill in real values. `.env` IS read at build/run time, via Flutter's
# --dart-define-from-file flag. lib/config.dart picks each value up with
# const String.fromEnvironment(...).
#
# Local dev (one flag, not four):
#   flutter run --dart-define-from-file=.env
#   flutter build apk --dart-define-from-file=.env
#
# VS Code: .vscode/launch.json and .vscode/tasks.json already pass this flag,
# so F5 / Run-and-Debug / Ctrl-Shift-B "just work" against `.env`.
#
# Netlify: same keys live in Site settings → Environment variables.
# netlify.toml expands them into --dart-define args at build time (no .env on
# the build server).
#
# Auth0 dashboard for the SPA app must allow the client URL:
#   - Local: http://localhost:5000 in Callback / Logout / Web Origin URLs
#   - Prod:  https://<netlify-domain> in the same three slots

AUTH0_DOMAIN=your-tenant.us.auth0.com

# Auth0 needs ONE app per platform — Native callbacks use custom URL schemes,
# Web/PWA callbacks use https URLs. We carry both Client IDs and lib/config.dart
# picks via kIsWeb at build time. Set both even if you're only deploying one
# target so the build does not fail.
AUTH0_CLIENT_ID_WEB=your_spa_client_id
AUTH0_CLIENT_ID_NATIVE=your_native_client_id

# IMPORTANT: AUTH0_AUDIENCE is the API identifier in Auth0 (no /api suffix);
# API_BASE_URL is the actual REST base (with /api). They differ on purpose.
AUTH0_AUDIENCE=https://api.example.com
API_BASE_URL=https://api.example.com/api
